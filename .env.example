DATABASE_URL="postgresql://postgres:postgres@localhost:5432/legal_chatbot"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""

EMBEDDING_PROVIDER="none"
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
VOYAGE_API_KEY=""
VOYAGE_EMBEDDING_MODEL=""

NEXT_PUBLIC_APP_NAME="정비사업 법령 AI"
MAX_UPLOAD_SIZE_MB="20"

# 최초 1회 관리자 계정 부트스트랩용. 셋 다 채워야 생성이 시도되며, 이미
# 같은 이메일의 사용자가 있으면 아무 것도 하지 않는다(비밀번호를 덮어쓰지 않음).
# 최초 로그인 성공 후에는 이 세 값을 반드시 배포 환경변수에서 제거할 것.
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_ADMIN_NAME=""

# 개발 전용 인증 우회. NODE_ENV=production에서는 이 값이 true여도 절대
# 우회되지 않으며, 오히려 앱이 기동에 실패한다. 로컬 개발에서만 사용할 것.
DEV_AUTH_BYPASS="false"

# 업로드 원본 파일 저장소. "local"은 단일 서버 로컬 디스크 전용 개발용이며,
# 서버리스·다중 인스턴스 운영 환경에서는 "s3"로 설정해야 한다.
STORAGE_PROVIDER="local"
STORAGE_LOCAL_ROOT="storage/uploads"

# STORAGE_PROVIDER="s3"일 때만 사용한다. AWS S3라면 STORAGE_S3_ENDPOINT는 비워두고,
# Cloudflare R2/MinIO 등 S3 호환 스토리지라면 해당 엔드포인트를 지정한다.
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION="us-east-1"
STORAGE_S3_ENDPOINT=""
STORAGE_S3_FORCE_PATH_STYLE="false"
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""
