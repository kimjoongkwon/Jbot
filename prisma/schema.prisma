generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  REVIEWER
  USER
}

enum DocumentType {
  LAW
  PRESIDENTIAL_DECREE
  MINISTERIAL_ORDINANCE
  LOCAL_ORDINANCE
  LOCAL_RULE
  ADMINISTRATIVE_RULE
  OFFICIAL_INTERPRETATION
  COURT_CASE
  ADMINISTRATIVE_APPEAL
  INTERNAL_MEMO
  OTHER
}

enum DocumentStatus {
  DRAFT
  PROCESSING
  ACTIVE
  INACTIVE
  ERROR
}

enum JurisdictionType {
  NATIONAL
  METROPOLITAN
  BASIC
}

enum BusinessType {
  REDEVELOPMENT
  RECONSTRUCTION
  STREET_HOUSING
  SMALL_RECONSTRUCTION
  SMALL_REDEVELOPMENT
  SELF_HOUSING
  MOATOWN
  OTHER
}

enum ProcedureStage {
  DISTRICT_DESIGNATION
  PROMOTION_COMMITTEE
  ASSOCIATION_ESTABLISHMENT
  PROJECT_IMPLEMENTATION_PLAN
  MANAGEMENT_DISPOSITION_PLAN
  CONTRACTOR_SELECTION
  RELOCATION_DEMOLITION
  CONSTRUCTION_COMPLETION
  LIQUIDATION
  OTHER
}

enum ParsingStatus {
  PENDING
  SUCCESS
  NO_TEXT_EXTRACTED
  FAILED
}

enum ChunkType {
  DOCUMENT_TITLE
  CHAPTER
  SECTION
  ARTICLE
  PARAGRAPH
  ITEM
  SUB_ITEM
  APPENDIX
  TABLE
  INTERPRETATION
  CASE_SUMMARY
  GENERAL_TEXT
}

enum IngestionStatus {
  PENDING
  PARSING
  CHUNKING
  EMBEDDING
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum AnswerConfidence {
  HIGH
  MEDIUM
  LOW
}

enum ReviewStatus {
  PENDING
  REVIEWED
  NEEDS_CORRECTION
  APPROVED
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum FeedbackReason {
  HELPFUL
  INCORRECT
  MISSING_CITATION
  OUTDATED_SOURCE
  WRONG_REGION
  UNSUPPORTED_CONCLUSION
  OTHER
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatSessions ChatSession[]
  feedbacks    AnswerFeedback[]
  auditLogs    AuditLog[]
}

model LegalDocument {
  id               String           @id @default(cuid())
  title            String
  shortTitle       String?
  documentType     DocumentType
  jurisdictionType JurisdictionType
  jurisdictionName String
  businessTypes    BusinessType[]
  issuingAuthority String?
  sourceUrl        String?
  description      String?
  status           DocumentStatus   @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  versions  DocumentVersion[]
  auditLogs AuditLog[]

  @@index([documentType])
  @@index([jurisdictionType, jurisdictionName])
  @@index([status])
}

model DocumentVersion {
  id                String         @id @default(cuid())
  legalDocumentId   String
  legalDocument     LegalDocument  @relation(fields: [legalDocumentId], references: [id], onDelete: Cascade)
  versionLabel      String
  promulgationDate  DateTime?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  isCurrent         Boolean        @default(true)
  originalFilename  String
  mimeType          String
  storagePath       String
  contentHash       String         @unique
  rawText           String?
  parsingStatus     ParsingStatus  @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  chunks        LegalChunk[]
  ingestionJobs IngestionJob[]

  @@index([legalDocumentId])
  @@index([isCurrent])
}

model LegalChunk {
  id                String   @id @default(cuid())
  documentVersionId String
  documentVersion   DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  chunkType         ChunkType
  articleNumber     String?
  articleTitle      String?
  paragraphNumber   String?
  itemNumber        String?
  subItemNumber     String?
  hierarchyPath     String
  content           String
  normalizedContent String
  searchText        String
  // 임베딩 미설정(NoopEmbeddingProvider) 시 null. pgvector 컬럼은 Prisma Client로
  // 직접 읽고 쓸 수 없어 raw SQL(src/lib/db/vector.ts)로만 접근한다.
  embedding         Unsupported("vector(1536)")?
  tokenCount        Int
  sequence          Int
  createdAt         DateTime @default(now())

  citations AnswerCitation[]

  @@index([documentVersionId])
  @@index([articleNumber])
  @@index([chunkType])
}

model IngestionJob {
  id                String           @id @default(cuid())
  documentVersionId String
  documentVersion   DocumentVersion  @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  status            IngestionStatus  @default(PENDING)
  totalChunks       Int              @default(0)
  processedChunks   Int              @default(0)
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())

  @@index([documentVersionId])
  @@index([status])
}

model ChatSession {
  id             String          @id @default(cuid())
  userId         String?
  user           User?           @relation(fields: [userId], references: [id])
  title          String?
  region         String?
  businessType   BusinessType?
  procedureStage ProcedureStage?
  referenceDate  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id               String            @id @default(cuid())
  chatSessionId    String
  chatSession      ChatSession       @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  role             MessageRole
  content          String
  structuredAnswer Json?
  confidence       AnswerConfidence?
  reviewStatus     ReviewStatus      @default(PENDING)
  createdAt        DateTime          @default(now())

  citations AnswerCitation[]
  feedbacks AnswerFeedback[]

  @@index([chatSessionId])
  @@index([reviewStatus])
}

model AnswerCitation {
  id              String       @id @default(cuid())
  chatMessageId   String
  chatMessage     ChatMessage  @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  legalChunkId    String
  legalChunk      LegalChunk   @relation(fields: [legalChunkId], references: [id])
  citationOrder   Int
  quotedText      String
  relevanceScore  Float?
  citationReason  String?
  createdAt       DateTime     @default(now())

  @@index([chatMessageId])
  @@index([legalChunkId])
}

model AnswerFeedback {
  id            String         @id @default(cuid())
  chatMessageId String
  chatMessage   ChatMessage    @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  rating        FeedbackRating
  reason        FeedbackReason
  comment       String?
  createdAt     DateTime       @default(now())

  @@index([chatMessageId])
}

model AuditLog {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  action          String
  targetType      String
  targetId        String?
  legalDocumentId String?
  legalDocument   LegalDocument? @relation(fields: [legalDocumentId], references: [id])
  metadata        Json?
  createdAt       DateTime       @default(now())

  @@index([legalDocumentId])
  @@index([action])
}
